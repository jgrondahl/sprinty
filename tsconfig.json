{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@splinty/core": ["packages/core/src"],
      "@splinty/agents": ["packages/agents/src"],
      "@splinty/integrations": ["packages/integrations/src"]
    }
  }
}
